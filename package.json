{
  "name": "countable-coin-paper",
  "version": "1.0.0",
  "description": "Countable Coin — On-Chain Accounting Semantic Layer. Reproduction code for IEEE ICBC / BCCA paper.",
  "keywords": [
    "ethereum",
    "erc20",
    "blockchain",
    "accounting",
    "semantic-finality",
    "smart-contract",
    "hardhat",
    "solidity"
  ],
  "author": "Countable Coin Research",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/taihwan-choi/countable-coin-paper.git"
  },
  "bugs": {
    "url": "https://github.com/taihwan-choi/countable-coin-paper/issues"
  },
  "homepage": "https://github.com/taihwan-choi/countable-coin-paper#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "preinstall": "echo 'If install fails, run: npm install --legacy-peer-deps'",
    "compile": "hardhat compile",
    "test": "hardhat test",
    "clean": "hardhat clean",
    "node": "hardhat node",
    "deploy:local": "hardhat run scripts/deploy_local.js --network localhost",
    "setup:local": "hardhat run scripts/setup_local.js  --network localhost",
    "emit:local": "hardhat run scripts/emit_local.js   --network localhost",
    "benchmark": "hardhat run scripts/benchmark_table2.js --network localhost",
    "gas:compare": "hardhat run scripts/gas_compare.js      --network localhost",
    "watcher": "node watcher/index.js",
    "dashboard": "node dashboard/server.js",
    "wallet-ui": "node wallet-ui/server.js",
    "check:repo": "bash check_repo.sh"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.1.2",
    "@nomicfoundation/hardhat-ethers": "^3.1.3",
    "@nomicfoundation/hardhat-ignition": "^0.15.16",
    "@nomicfoundation/hardhat-ignition-ethers": "^0.15.17",
    "@nomicfoundation/hardhat-network-helpers": "^1.1.2",
    "@nomicfoundation/hardhat-toolbox": "^6.1.2",
    "@nomicfoundation/hardhat-verify": "^2.1.3",
    "@nomicfoundation/ignition-core": "^0.15.15",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.1.0",
    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.10",
    "chai": "^4.5.0",
    "hardhat": "^2.28.6",
    "hardhat-gas-reporter": "^2.3.0",
    "solidity-coverage": "^0.8.17",
    "ts-node": "^10.9.2",
    "typechain": "^8.3.2",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.0.0",
    "better-sqlite3": "^9.0.0",
    "dotenv": "^16.0.0",
    "ethers": "^6.0.0",
    "express": "^4.18.0",
    "node-fetch": "^2.7.0"
  }
}
