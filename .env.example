# ══════════════════════════════════════════════════════════════
# .env.example — 환경변수 템플릿
# 이 파일을 .env로 복사한 후 실제 값을 채우세요:
#   cp .env.example .env
#
# ⚠️  .env 파일은 절대 GitHub에 커밋하지 마세요.
#      .gitignore에 이미 포함되어 있습니다.
# ══════════════════════════════════════════════════════════════


# ──────────────────────────────────────────────
# 체인 설정 (JSON 배열)
# deploy_local.js 실행 후 contract 주소를 교체하세요.
# ──────────────────────────────────────────────
CHAINS_JSON=[{"name":"local","rpc":"http://127.0.0.1:8545","contract":"0x여기에배포주소입력"}]

# 단축 주소 (위 CHAINS_JSON의 contract와 동일하게 설정)
COIN_ADDR=0x여기에배포주소입력


# ──────────────────────────────────────────────
# 로그 / 데이터 경로 (기본값 그대로 사용 권장)
# ──────────────────────────────────────────────
LOG_DIR=./logs
DATA_DIR=./data
DB_PATH=./data/countable.db


# ──────────────────────────────────────────────
# 웹훅 (ERP 연동 — 선택사항)
# WEBHOOK_ENABLED=true 로 바꾸고 URL을 설정하면 이벤트마다 POST됩니다.
# ──────────────────────────────────────────────
WEBHOOK_ENABLED=false
WEBHOOK_URL=


# ──────────────────────────────────────────────
# 대시보드 포트
# ──────────────────────────────────────────────
API_PORT=8088
DASH_PORT=8088


# ──────────────────────────────────────────────
# (선택) 테스트넷 / 메인넷 배포 시에만 필요
# 로컬 Hardhat 사용 시에는 비워 두세요.
# ──────────────────────────────────────────────
# PRIVATE_KEY=
# SEPOLIA_RPC_URL=
# ETHERSCAN_API_KEY=
